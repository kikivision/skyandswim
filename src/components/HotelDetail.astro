---
import { Image } from "astro:assets";
import { AFFILIATE_HOTELS } from "../data/affiliates.js";

// Shared hotel-detail view. Rendered by the per-city route
// (src/pages/cities/[city]/[hotel].astro) and by standalone hotel pages that
// have no city home (e.g. Four Seasons Seattle, an Editor's Pick with no
// Seattle city). Keeping the markup + styles here means the two never drift.
//
// citySlug is nullable: when null the page is standalone — the breadcrumb drops
// the city link and the "more in <city>" section is omitted (siblings empty).

interface Props {
  hotel: Record<string, any>;
  city: string;
  state: string;
  citySlug?: string | null;
  siblings?: Array<Record<string, any>>;
  /** Optional non-city parent crumb (e.g. Notable Pools) for standalone pages
      that have no city home. Ignored when citySlug is set. */
  parentLabel?: string | null;
  parentHref?: string | null;
}

const {
  hotel,
  city,
  state,
  citySlug = null,
  siblings = [],
  parentLabel = null,
  parentHref = null,
} = Astro.props;

// Hero images are keyed by hotel slug: src/assets/hotels/<slug>.jpg. Same glob
// the route used before extraction, so Astro still optimizes (webp + srcset).
const heroFiles = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/hotels/*.{jpg,jpeg,png,webp}",
  { eager: true },
);
const heroBySlug = Object.fromEntries(
  Object.entries(heroFiles).map(([path, mod]) => [
    path.split("/").pop().replace(/\.\w+$/, ""),
    mod.default,
  ]),
);
const hero = heroBySlug[hotel.slug];
const photoCredit = hotel.heroCredit;

// poolNote is authored as a "·"-separated run of facts — split it back out.
const poolFacts = hotel.poolNote
  .split("·")
  .map((s) => s.trim())
  .filter(Boolean);

// Only hotels with an entry in affiliates.js get a /go link.
const hasAffiliate = Boolean(hotel.slug && hotel.slug in AFFILIATE_HOTELS);
const ctaHref = hasAffiliate ? `/go/booking/${hotel.slug}/` : (hotel.bookingUrl ?? "#");
const isOutbound = ctaHref !== "#";
const ctaRel = !isOutbound
  ? undefined
  : hasAffiliate
    ? "noopener noreferrer sponsored"
    : "noopener noreferrer";
---

<article class="hotel-page">
  <header class="hotel-hero">
    <div class="section-inner">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Sky &amp; Swim</a>
        {citySlug ? (
          <>
            <span aria-hidden="true">/</span>
            <a href={`/cities/${citySlug}/`}>{city}</a>
          </>
        ) : parentHref ? (
          <>
            <span aria-hidden="true">/</span>
            <a href={parentHref}>{parentLabel}</a>
          </>
        ) : null}
        <span aria-hidden="true">/</span>
        <span aria-current="page">{hotel.name}</span>
      </nav>

      <p class="hero-kicker">
        {hotel.neighborhood} · {city}, {state}
        {hotel.priceRange && <span class="hero-price">{hotel.priceRange}</span>}
      </p>
      <h1 class="hero-name">{hotel.name}</h1>
      {hotel.pick && <p class="hero-pick">✦ Sky &amp; Swim Pick</p>}
    </div>
  </header>

  {hero && (
    <figure class="hero-figure">
      <div class="section-inner">
        <Image
          class="hero-img"
          src={hero}
          alt={`The rooftop pool at ${hotel.name}, ${city}.`}
          widths={[640, 960, 1440]}
          sizes="(max-width: 900px) 100vw, 1200px"
          loading="eager"
          fetchpriority="high"
        />
        {photoCredit && (
          <figcaption class="hero-credit">
            Photo courtesy of {photoCredit}.
          </figcaption>
        )}
      </div>
    </figure>
  )}

  <div class="section-inner hotel-body">
    <section class="block" aria-labelledby="pool-heading">
      <h2 id="pool-heading">The pool</h2>
      <ul class="facts">
        {poolFacts.map((f) => (
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2" />
              <path d="M4 8.5 C5.5 6.5 8.5 6.5 10 8.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="block" aria-labelledby="take-heading">
      <h2 id="take-heading">Why it's on the list</h2>
      <p class="take">{hotel.description}</p>
      {hotel.tags?.length > 0 && (
        <div class="tags" aria-label="Tags">
          {hotel.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </section>

    {hotel.stay && (
      <section class="block" aria-labelledby="stay-heading">
        <h2 id="stay-heading">The stay</h2>
        <p class="take">{hotel.stay}</p>
      </section>
    )}

    {isOutbound && (
      <section class="cta-block">
        <a class="cta" href={ctaHref} target="_blank" rel={ctaRel}>
          See rooms &amp; rates at {hotel.name}
          <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 6h7M6.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        {hasAffiliate && (
          <p class="cta-note">
            We may earn a commission if you book through this link — it never
            changes what you pay, or what makes the list.
          </p>
        )}
      </section>
    )}

    {siblings.length > 0 && (
      <section class="block siblings" aria-labelledby="more-heading">
        <h2 id="more-heading">More rooftop pools in {city}</h2>
        <ul class="sibling-list">
          {siblings.map((s) => (
            <li>
              <a href={`/cities/${citySlug}/${s.slug}/`}>
                <span class="sib-name">{s.name}</span>
                <span class="sib-hood">{s.neighborhood}</span>
              </a>
            </li>
          ))}
        </ul>
        <a class="all-link" href={`/cities/${citySlug}/`}>
          All {city} rooftop pool hotels →
        </a>
      </section>
    )}
  </div>
</article>

<style>
  .hotel-hero {
    padding: 8rem 0 clamp(2rem, 5vw, 3.5rem);
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.76rem;
    letter-spacing: 0.04em;
    color: rgba(220, 240, 245, 0.6);
    margin-bottom: 1.6rem;
  }
  .crumbs a { color: rgba(220, 240, 245, 0.85); text-decoration: underline; text-underline-offset: 3px; }
  .crumbs a:hover { color: #fff; }
  .crumbs [aria-current] { color: rgba(220, 240, 245, 0.6); }

  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--teal);
    margin: 0 0 0.7rem;
  }
  .hero-price { color: rgba(220, 240, 245, 0.55); letter-spacing: 0.08em; }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 6.5vw, 4.6rem);
    line-height: 1;
    color: #fff;
    margin: 0;
  }
  .hero-pick {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--watermelon);
    margin: 1rem 0 0;
  }

  /* Hero image — sits between the title block and the facts, so the pool is the
     first thing you see after the name. */
  .hero-figure {
    margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
  }
  .hero-img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 12px;
    background: rgba(6, 26, 44, 0.4);
  }
  /* Discreet property credit, as required for Fora Portal photography. */
  .hero-credit {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.72rem;
    line-height: 1.4;
    color: rgba(220, 240, 245, 0.5);
    margin: 0.7rem 0 0;
    text-align: right;
  }

  .hotel-body { padding-bottom: clamp(4rem, 8vw, 7rem); }

  .block { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); max-width: 72ch; }
  .block h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    color: #fff;
    margin: 0 0 1.1rem;
  }

  .facts { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.65rem; }
  .facts li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.98rem;
    line-height: 1.5;
    color: rgba(220, 240, 245, 0.88);
  }
  .facts svg { flex: none; margin-top: 0.22rem; color: var(--teal); }

  .take {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(220, 240, 245, 0.88);
    margin: 0;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1.3rem; }
  .tag {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(220, 240, 245, 0.8);
    border: 1px solid rgba(168, 216, 216, 0.28);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
  }

  .cta-block { margin: 0 0 clamp(2.5rem, 5vw, 3.5rem); max-width: 72ch; }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    color: #fff;
    background: var(--watermelon);
    border-radius: 999px;
    padding: 0.9rem 1.6rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .cta:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(212, 72, 104, 0.35); }
  .cta-note {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.78rem;
    line-height: 1.5;
    color: rgba(220, 240, 245, 0.55);
    margin: 0.9rem 0 0;
    max-width: 48ch;
  }

  .siblings { border-top: 1px solid rgba(168, 216, 216, 0.18); padding-top: clamp(2rem, 4vw, 2.8rem); }
  .sibling-list { list-style: none; margin: 0 0 1.4rem; padding: 0; display: grid; gap: 1px; background: rgba(168, 216, 216, 0.16); border: 1px solid rgba(168, 216, 216, 0.16); border-radius: 10px; overflow: hidden; }
  .sibling-list a {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 0.8rem;
    padding: 0.95rem 1.2rem;
    background: rgba(6, 26, 44, 0.4);
    transition: background 0.2s ease;
  }
  .sibling-list a:hover { background: rgba(6, 26, 44, 0.62); }
  .sib-name { font-family: var(--font-display); font-size: 1.15rem; color: #fff; }
  .sib-hood { font-family: var(--font-body); font-weight: 300; font-size: 0.8rem; color: rgba(220, 240, 245, 0.6); }

  .all-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--teal);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .all-link:hover { color: #fff; }

  @media (max-width: 640px) {
    .hotel-hero { padding-top: 6.5rem; }
  }
</style>

---
import { AFFILIATE_HOTELS } from "../data/affiliates.js";

interface Props {
  name: string;
  neighborhood: string;
  description: string;
  poolNote: string;
  tags: string[];
  bookingUrl?: string;
  slug?: string; // affiliate slug (src/data/affiliates.js) → routes CTA through /go
  pick?: boolean;
  priceRange?: string; // "$" | "$$" | "$$$" | "$$$$"
  /** Internal hotel page (/cities/<city>/<hotel>/). When set, the card title
      links here instead of straight out, so the detail pages are crawlable
      from the city listing and readers get our take before the booking site. */
  detailHref?: string;
}

const {
  name,
  neighborhood,
  description,
  poolNote,
  tags,
  bookingUrl = "#",
  slug,
  pick = false,
  priceRange,
  detailHref,
} = Astro.props;

// Affiliate hotels route through the /go redirector (provider-attributed click
// tracking + CJ wrapping); everything else uses the direct link as before.
// `slug` doubles as the hotel-page URL segment, so having one does NOT imply an
// affiliate destination exists — gate on AFFILIATE_HOTELS or we emit a /go link
// to a page that was never generated.
const hasAffiliate = Boolean(slug && slug in AFFILIATE_HOTELS);
const ctaHref = hasAffiliate ? `/go/booking/${slug}/` : bookingUrl;
const isOutbound = ctaHref !== "#";
const ctaRel = !isOutbound
  ? undefined
  : hasAffiliate
    ? "noopener noreferrer sponsored"
    : "noopener noreferrer";
---

<article class={`hotel-card ${pick ? "hotel-card--pick" : ""}`}>
  <div class="card-pool-accent" aria-hidden="true"></div>

  <div class="card-inner">
    <header class="card-header">
      <div class="card-meta-row">
        <span class="card-neighborhood">{neighborhood}</span>
        {priceRange && <span class="card-price">{priceRange}</span>}
        {pick && <span class="card-pick-badge">✦ Editor's Pick</span>}
      </div>
      <h3 class="card-name">
        {detailHref ? (
          <a class="card-name-link card-name-link--stretched" href={detailHref}>{name}</a>
        ) : isOutbound ? (
          <a class="card-name-link" href={ctaHref} target="_blank" rel={ctaRel}>{name}</a>
        ) : (
          name
        )}
      </h3>
    </header>

    <p class="card-description">{description}</p>

    <div class="card-pool-note">
      <svg class="pool-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/>
        <path d="M4 8.5 C5.5 6.5 8.5 6.5 10 8.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <span>{poolNote}</span>
    </div>

    {tags.length > 0 && (
      <div class="card-tags" aria-label="Tags">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}

    <div class="card-actions">
      {detailHref && (
        <a class="card-detail-link" href={detailHref}>
          See the pool
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 6h7M6.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      )}
      {isOutbound && (
        <a class="card-cta" href={ctaHref} target="_blank" rel={ctaRel}>
          See rooms &amp; rates
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 6h7M6.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</article>

<style>
  /* The card is a subgrid spanning five rows of the page's .hotel-grid: header,
     description, pool note, tags, actions. Cards sharing a grid row therefore
     share track heights, so the pool-note strip starts at the same height on
     every card in the row and the CTA row sits on a common bottom line, however
     long each description runs. Browsers without subgrid (and standalone usage
     outside a grid) fall back to plain auto rows — the card just sizes to its
     own content, which is the old behavior. */
  .hotel-card {
    position: relative;
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 5;
    row-gap: 1rem;
    padding: clamp(1.4rem, 2.5vw, 2rem);
    background: rgba(8, 30, 56, 0.75);
    border: 1px solid rgba(168, 216, 216, 0.15);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .hotel-card:hover {
    border-color: rgba(42, 191, 191, 0.4);
    transform: translateY(-2px);
  }

  .hotel-card--pick {
    border-color: rgba(212, 72, 104, 0.65);
    box-shadow: inset 0 0 0 1px rgba(212, 72, 104, 0.35);
    background: rgba(7, 28, 52, 0.82);
  }
  .hotel-card--pick:hover {
    border-color: rgba(212, 72, 104, 0.9);
  }

  /* Subtle pool shimmer along the top edge */
  .card-pool-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, rgba(42,191,191,0.6) 40%, rgba(168,216,216,0.4) 60%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .hotel-card:hover .card-pool-accent { opacity: 1; }
  .hotel-card--pick .card-pool-accent {
    background: linear-gradient(90deg, transparent 0%, rgba(212,72,104,0.7) 40%, rgba(212,72,104,0.5) 60%, transparent 100%);
    opacity: 0.6;
  }

  /* Dissolved so the five sections become direct subgrid items of the card;
     its old padding and gap now live on .hotel-card. */
  .card-inner {
    display: contents;
  }

  /* Pin each section to its track so a missing section (e.g. a card with no
     tags) leaves its row empty instead of shifting everything below it up. */
  .card-header { grid-row: 1; display: flex; flex-direction: column; gap: 0.45rem; }
  .card-description { grid-row: 2; }
  .card-pool-note { grid-row: 3; align-self: start; }
  .card-tags { grid-row: 4; align-self: start; }
  .card-actions { grid-row: 5; align-self: end; }

  .card-meta-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .card-neighborhood {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--teal);
  }

  .card-price {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    color: rgba(196, 222, 229, 0.92);
    letter-spacing: 0.05em;
  }

  .card-pick-badge {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    background: var(--watermelon);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }

  .card-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    line-height: 1.1;
    color: #fff;
    margin: 0;
  }

  .card-name-link {
    color: inherit;
    transition: color 0.2s ease;
  }

  .card-name-link:hover {
    color: var(--teal);
  }

  .card-description {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgba(220, 240, 245, 0.78);
    margin: 0;
  }

  .card-pool-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 400;
    color: rgba(168, 216, 216, 0.75);
    line-height: 1.4;
    padding: 0.7rem 0.9rem;
    background: rgba(42, 191, 191, 0.08);
    border-radius: 6px;
    border-left: 2px solid rgba(42, 191, 191, 0.4);
  }

  .pool-icon {
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--teal);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    color: rgba(168, 216, 216, 0.7);
    background: rgba(42, 191, 191, 0.1);
    border: 1px solid rgba(42, 191, 191, 0.2);
    padding: 0.22rem 0.6rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Stretched link — the whole card is a click target for our detail page, so
     readers land on the write-up rather than only ever hitting the booking CTA.
     Applied via ::after on the title link (no nested <a>, so the markup stays
     valid and screen readers still announce one link named for the hotel).
     Deliberately scoped to the detailHref case: the full card must never become
     an outbound affiliate target. */
  .card-name-link--stretched::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .card-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.1rem;
  }

  /* Both action links are lifted above the stretched card overlay so each stays
     independently clickable. Scoped to the links themselves rather than the row,
     so blank space beside them still targets the detail page like the rest of
     the card. */
  .card-detail-link,
  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    position: relative;
    z-index: 2;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  /* Internal link to the hotel page — the hero photo and "The pool" facts —
     listed ahead of the outbound booking CTA so readers see there's more to
     look at before they leave. */
  .card-detail-link {
    color: rgba(220, 240, 245, 0.75);
  }

  .card-cta {
    color: var(--teal);
  }

  .card-detail-link:hover,
  .card-cta:hover {
    color: #fff;
    gap: 0.65rem;
  }
</style>

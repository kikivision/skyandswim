---
const cities = [
  {
    name: "New York",
    meta: "9 rooftop pools · Manhattan & Brooklyn",
    badge: "Most covered",
    href: "#",
    area: "nyc",
  },
  {
    name: "Miami",
    meta: "7 rooftop pools · South Beach & Brickell",
    badge: null,
    href: "#",
    area: "miami",
  },
  {
    name: "Nashville",
    meta: "4 rooftop pools · The Gulch",
    badge: null,
    href: "#",
    area: "nashville",
  },
  {
    name: "Austin",
    meta: "5 rooftop pools · Downtown & Rainey St",
    badge: "Rising",
    href: "#",
    area: "austin",
  },
  {
    name: "Chicago",
    meta: "5 rooftop pools · River North",
    badge: null,
    href: "#",
    area: "chicago",
  },
  {
    name: "New Orleans",
    meta: "3 rooftop pools · Warehouse District",
    badge: null,
    href: "#",
    area: "nola",
  },
  {
    name: "Denver",
    meta: "4 rooftop pools · LoDo & RiNo",
    badge: null,
    href: "#",
    area: "denver",
  },
];
---

<section class="cities" id="cities" aria-labelledby="cities-heading">
  <div class="section-inner">
    <header class="cities-head">
      <p class="kicker">Browse by city</p>
      <h2 id="cities-heading">Pick a skyline.</h2>
      <p class="lede">
        Fifteen US cities, mapped pool by pool. Start where the water's already
        warm.
      </p>
    </header>

    <div class="grid">
      {
        cities.map((city) => (
          <a class={`card card-${city.area}`} href={city.href}>
            <span class="card-water" aria-hidden="true" />
            <span class="card-overlay" aria-hidden="true" />
            <span class="card-body">
              {city.badge && <span class="card-badge">{city.badge}</span>}
              <span class="card-name">{city.name}</span>
              <span class="card-meta">{city.meta}</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cities {
    padding: clamp(4rem, 9vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .cities-head {
    margin-bottom: 2.4rem;
    max-width: 40ch;
  }

  .kicker {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--teal);
    margin-bottom: 0.9rem;
  }

  .cities-head h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    line-height: 1.05;
    color: #fff;
  }

  .lede {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.55;
    color: rgba(220, 240, 245, 0.75);
    margin-top: 0.9rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 150px;
    gap: 1px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 14px;
    overflow: hidden;
  }

  /* Bento placement */
  .card-nyc {
    grid-column: span 5;
    grid-row: span 2;
  }
  .card-miami {
    grid-column: span 4;
  }
  .card-nashville {
    grid-column: span 3;
  }
  .card-austin {
    grid-column: span 7;
  }
  .card-chicago {
    grid-column: span 4;
  }
  .card-nola {
    grid-column: span 3;
  }
  .card-denver {
    grid-column: span 5;
  }

  .card {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    background: rgba(6, 26, 44, 0.45);
    isolation: isolate;
  }

  /* Dark base tint per card so the gradient reads as "depth" behind glass */
  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(5, 20, 40, 0.15) 0%,
      rgba(5, 20, 40, 0.55) 100%
    );
    transition: background 0.4s ease;
  }

  /* Pool water accent — teal gradient sweeping up from the base */
  .card-water {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
        120% 80% at 20% 120%,
        rgba(42, 191, 191, 0.45) 0%,
        rgba(42, 191, 191, 0) 55%
      ),
      linear-gradient(180deg, rgba(26, 90, 112, 0) 40%, rgba(42, 140, 170, 0.35) 100%);
    opacity: 0.65;
    transform: scale(1);
    transition:
      transform 0.5s ease,
      opacity 0.4s ease;
  }

  .card-body {
    position: relative;
    z-index: 2;
    padding: clamp(1.1rem, 2vw, 1.6rem);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .card-badge {
    align-self: flex-start;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #fff;
    background: var(--watermelon);
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.45rem;
  }

  .card-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 2.6vw, 2.2rem);
    line-height: 1;
    color: #fff;
  }

  .card-nyc .card-name {
    font-size: clamp(2rem, 3.6vw, 3rem);
  }

  .card-meta {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.82rem;
    color: rgba(220, 240, 245, 0.78);
  }

  .card:hover .card-water {
    transform: scale(1.05);
    opacity: 0.95;
  }

  .card:hover .card-overlay {
    background: linear-gradient(
      180deg,
      rgba(5, 20, 40, 0.05) 0%,
      rgba(5, 20, 40, 0.45) 100%
    );
  }

  @media (max-width: 760px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 140px;
    }

    .card-nyc {
      grid-column: span 2;
      grid-row: span 2;
    }
    .card-miami,
    .card-nashville,
    .card-austin,
    .card-chicago,
    .card-nola,
    .card-denver {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>

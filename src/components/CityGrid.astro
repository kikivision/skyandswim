---
import { CITIES } from "../data/hotels.js";

// Presentation only — bento placement, badge, and a short neighborhood label
// for the compact card. Name and pool count come from src/data/hotels.js so the
// grid can never drift out of sync with the city pages.
const layout = [
  { slug: "new-york", area: "nyc", badge: "Most covered", hood: "Manhattan & Brooklyn" },
  { slug: "los-angeles", area: "la", badge: "New", hood: "Hollywood & Downtown" },
  { slug: "miami", area: "miami", badge: null, hood: "South Beach & Brickell" },
  { slug: "dallas", area: "dallas", badge: "New", hood: "Downtown & Uptown" },
  { slug: "chicago", area: "chicago", badge: null, hood: "Gold Coast & Fulton Market" },
  { slug: "san-diego", area: "sandiego", badge: "New", hood: "Gaslamp & Bayfront" },
  { slug: "austin", area: "austin", badge: "Rising", hood: "Downtown & Rainey St" },
  { slug: "phoenix", area: "phoenix", badge: "New", hood: "Phoenix & Scottsdale" },
  { slug: "denver", area: "denver", badge: null, hood: "Cherry Creek & Uptown" },
  { slug: "philadelphia", area: "philly", badge: "New", hood: "Center City & Old City" },
  { slug: "houston", area: "houston", badge: "New", hood: "Downtown & Montrose" },
  { slug: "washington-dc", area: "dc", badge: "New", hood: "Capitol Hill & Logan Circle" },
  { slug: "nashville", area: "nashville", badge: null, hood: "Downtown & Midtown" },
  { slug: "new-orleans", area: "nola", badge: null, hood: "Warehouse District" },
];

const cities = layout.map((l) => {
  const c = CITIES[l.slug];
  const count = c.hotels.length;
  return {
    name: c.city,
    meta: `${count} rooftop pool${count === 1 ? "" : "s"} · ${l.hood}`,
    badge: l.badge,
    // Trailing slash matters: without it every homepage city link 301s.
    href: `/cities/${l.slug}/`,
    area: l.area,
  };
});

const cityCount = new Intl.NumberFormat("en-US").format(cities.length);
const totalPools = Object.values(CITIES).reduce((n, c) => n + c.hotels.length, 0);
---

<section class="cities" id="cities" aria-labelledby="cities-heading">
  <div class="section-inner">
    <header class="cities-head">
      <p class="kicker">Browse by city</p>
      <h2 id="cities-heading">Pick a skyline.</h2>
      <p class="lede">
        {cityCount} US cities and {totalPools} pools, mapped one by one. Start
        where the water's already warm.
      </p>
    </header>

    <div class="grid">
      {
        cities.map((city) => (
          <a class={`card card-${city.area}`} href={city.href}>
            <span class="card-water" aria-hidden="true" />
            <span class="card-overlay" aria-hidden="true" />
            <span class="card-body">
              {city.badge && <span class="card-badge">{city.badge}</span>}
              <span class="card-name">{city.name}</span>
              <span class="card-meta">{city.meta}</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cities {
    padding: clamp(4rem, 9vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .cities-head {
    margin-bottom: 2.4rem;
    max-width: 40ch;
  }

  /* Soft dark halo so bare copy reads over the light pool surface —
     no box, keeps the floating-on-the-water look. */
  .cities-head .kicker,
  .cities-head h2,
  .cities-head .lede {
    text-shadow:
      0 1px 2px rgba(3, 12, 28, 0.6),
      0 2px 16px rgba(3, 12, 28, 0.72);
  }

  .kicker {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #fff;
    margin-bottom: 0.9rem;
  }

  .cities-head h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    line-height: 1.05;
    color: #fff;
  }

  .lede {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.55;
    color: rgba(220, 240, 245, 0.75);
    margin-top: 0.9rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 150px;
    gap: 1px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 14px;
    overflow: hidden;
  }

  /* Bento placement — 14 cities in a 12-col grid.
     Row 1-2: NYC feature (6×2) + LA (6). Row 2: Miami + Dallas (3+3 beside NYC).
     Row 3: Chicago/San Diego/Austin/Phoenix (3 each).
     Row 4: Denver/Philadelphia/Houston (4 each).
     Row 5: Washington/Nashville/NOLA (4 each). */
  .card-nyc {
    grid-column: span 6;
    grid-row: span 2;
  }
  .card-la {
    grid-column: span 6;
  }
  .card-miami {
    grid-column: span 3;
  }
  .card-dallas {
    grid-column: span 3;
  }
  .card-chicago {
    grid-column: span 3;
  }
  .card-sandiego {
    grid-column: span 3;
  }
  .card-austin {
    grid-column: span 3;
  }
  .card-phoenix {
    grid-column: span 3;
  }
  .card-denver {
    grid-column: span 4;
  }
  .card-philly {
    grid-column: span 4;
  }
  .card-houston {
    grid-column: span 4;
  }
  .card-dc {
    grid-column: span 4;
  }
  .card-nashville {
    grid-column: span 4;
  }
  .card-nola {
    grid-column: span 4;
  }

  .card {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    background: rgba(6, 22, 40, 0.62);
    isolation: isolate;
  }

  /* Dark base tint per card so the gradient reads as "depth" behind glass */
  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(5, 20, 40, 0.35) 0%,
      rgba(5, 20, 40, 0.72) 100%
    );
    transition: background 0.4s ease;
  }

  /* Pool water accent — teal gradient sweeping up from the base */
  .card-water {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
        120% 80% at 20% 120%,
        rgba(42, 191, 191, 0.45) 0%,
        rgba(42, 191, 191, 0) 55%
      ),
      linear-gradient(180deg, rgba(26, 90, 112, 0) 40%, rgba(42, 140, 170, 0.35) 100%);
    opacity: 0.65;
    transform: scale(1);
    transition:
      transform 0.5s ease,
      opacity 0.4s ease;
  }

  .card-body {
    position: relative;
    z-index: 2;
    padding: clamp(1.1rem, 2vw, 1.6rem);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .card-badge {
    align-self: flex-start;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #fff;
    background: var(--watermelon);
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.45rem;
  }

  .card-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 2.6vw, 2.2rem);
    line-height: 1;
    color: #fff;
  }

  .card-nyc .card-name {
    font-size: clamp(2rem, 3.6vw, 3rem);
  }

  .card-meta {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.82rem;
    color: rgba(220, 240, 245, 0.78);
  }

  .card:hover .card-water {
    transform: scale(1.05);
    opacity: 0.95;
  }

  .card:hover .card-overlay {
    background: linear-gradient(
      180deg,
      rgba(5, 20, 40, 0.05) 0%,
      rgba(5, 20, 40, 0.45) 100%
    );
  }

  @media (max-width: 760px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 140px;
    }

    .card-nyc {
      grid-column: span 2;
      grid-row: span 2;
    }
    .card-la,
    .card-miami,
    .card-dallas,
    .card-chicago,
    .card-sandiego,
    .card-austin,
    .card-phoenix,
    .card-philly,
    .card-houston,
    .card-dc,
    .card-nashville,
    .card-nola,
    .card-denver {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>

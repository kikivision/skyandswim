---
---

<section class="newsletter" id="about" aria-labelledby="newsletter-heading">
  <div class="newsletter-inner">
    <p class="kicker">The dispatch</p>
    <h2 id="newsletter-heading">
      New openings, heated pools, and weekend picks.
    </h2>
    <p class="sub">
      One short email when the water's worth it. Built for people who plan trips
      around a deck and a view.
    </p>

    <form class="signup" onsubmit="return false">
      <label class="visually-hidden" for="email">Email address</label>
      <input
        id="email"
        type="email"
        name="email"
        placeholder="you@example.com"
        autocomplete="email"
        required
      />
      <button type="submit">Subscribe</button>
    </form>

    <p class="fineprint">No spam. Unsubscribe anytime.</p>
  </div>
</section>

<style>
  .newsletter {
    background: rgba(4, 12, 28, 0.35);
    border-top: 1px solid rgba(42, 100, 130, 0.2);
    padding: clamp(4rem, 8vw, 6.5rem) clamp(1.25rem, 4vw, 3rem);
  }

  .newsletter-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .kicker {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--teal);
    margin-bottom: 1rem;
  }

  .newsletter h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    color: #fff;
  }

  .sub {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.02rem;
    line-height: 1.6;
    color: rgba(170, 205, 215, 0.7);
    margin: 1rem auto 0;
    max-width: 46ch;
  }

  .signup {
    display: flex;
    gap: 0.6rem;
    margin: 2rem auto 0;
    max-width: 460px;
  }

  .signup input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: #fff;
    padding: 0.9rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.06);
    transition: border-color 0.2s ease;
  }

  .signup input::placeholder {
    color: rgba(200, 225, 232, 0.5);
  }

  .signup input:focus {
    outline: none;
    border-color: var(--teal);
  }

  .signup button {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    color: #fff;
    background: var(--watermelon);
    border: none;
    padding: 0.9rem 1.7rem;
    border-radius: 999px;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .signup button:hover {
    background: #e0577a;
    transform: translateY(-2px);
  }

  .fineprint {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.8rem;
    color: rgba(150, 190, 205, 0.6);
    margin-top: 1.1rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 520px) {
    .signup {
      flex-direction: column;
    }

    .signup button {
      width: 100%;
    }
  }
</style>

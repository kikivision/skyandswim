---
const links = [
  { label: "Cities", href: "#cities" },
  { label: "Editor's Picks", href: "#picks" },
  { label: "About", href: "#about" },
  { label: "Affiliate Disclosure", href: "#" },
];
---

<footer class="footer">
  <div class="footer-inner">
    <a class="footer-logo" href="/">
      <svg class="footer-mark" viewBox="0 0 82 110" aria-hidden="true" focusable="false">
        <defs>
          <linearGradient id="footerDropFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#C8ECEC"></stop>
            <stop offset="50%" stop-color="#2ABFBF"></stop>
            <stop offset="100%" stop-color="#0A4858"></stop>
          </linearGradient>
          <radialGradient id="footerDropSheen" cx="0.36" cy="0.27" r="0.6">
            <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.65"></stop>
            <stop offset="55%" stop-color="#FFFFFF" stop-opacity="0.12"></stop>
            <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0"></stop>
          </radialGradient>
        </defs>
        <path
          d="M 41 2 C 41 2, 43 8, 62 36 C 74 54, 79 68, 79 78 C 79 95, 62 108, 41 108 C 20 108, 3 95, 3 78 C 3 68, 8 54, 20 36 C 39 8, 41 2, 41 2 Z"
          fill="url(#footerDropFill)"
        ></path>
        <path
          d="M 41 2 C 41 2, 43 8, 62 36 C 74 54, 79 68, 79 78 C 79 95, 62 108, 41 108 C 20 108, 3 95, 3 78 C 3 68, 8 54, 20 36 C 39 8, 41 2, 41 2 Z"
          fill="url(#footerDropSheen)"
        ></path>
      </svg>
      <span class="footer-word">Sky <span class="amp">&amp;</span> Swim</span>
    </a>

    <nav class="footer-links" aria-label="Footer">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <p class="copyright">
      © 2026 Sky &amp; Swim · A Sunstate Bay Ventures property
    </p>
  </div>
</footer>

<style>
  .footer {
    background: rgba(3, 8, 18, 0.5);
    border-top: 1px solid rgba(42, 100, 130, 0.2);
    padding: 2.6rem 0;
  }

  .footer-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
  }

  .footer-logo {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    color: rgba(140, 190, 205, 0.55);
    text-align: center;
  }

  .footer-mark {
    width: 32px;
    height: auto;
    display: block;
    /* Nudge left so the drop sits directly above the & in the wordmark. */
    transform: translateX(-9px);
  }

  .footer-logo .amp {
    color: rgba(78, 172, 184, 0.7);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(150, 190, 205, 0.7);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .copyright {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.8rem;
    color: rgba(120, 165, 180, 0.6);
    flex-basis: 100%;
  }

  @media (max-width: 620px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

---
const links = [
  { label: "Cities", href: "#cities" },
  { label: "Editor's Picks", href: "#picks" },
  { label: "About", href: "#about" },
  { label: "Affiliate Disclosure", href: "#" },
];
---

<footer class="footer">
  <div class="footer-inner">
    <a class="footer-logo" href="/">
      Sky <span class="amp">&amp;</span> Swim
    </a>

    <nav class="footer-links" aria-label="Footer">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <p class="copyright">
      © 2026 Sky &amp; Swim · A Sunstate Bay Ventures property
    </p>
  </div>
</footer>

<style>
  .footer {
    background: rgba(3, 8, 18, 0.5);
    border-top: 1px solid rgba(42, 100, 130, 0.2);
    padding: 2.6rem 0;
  }

  .footer-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    color: #fff;
  }

  .footer-logo .amp {
    color: rgba(78, 172, 184, 0.7);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(150, 190, 205, 0.7);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .copyright {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.8rem;
    color: rgba(120, 165, 180, 0.6);
    flex-basis: 100%;
  }

  @media (max-width: 620px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

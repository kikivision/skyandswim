---
const principles = [
  {
    numeral: "I",
    title: "The View Has to Matter",
    body: "A pool on a roof is not automatically special. We rank for the skyline, the water line, and that specific moment the light drops and the whole deck goes gold. If the view doesn't earn it, it doesn't make the list.",
  },
  {
    numeral: "II",
    title: "Adults Welcome, Chaotic Neutral",
    body: "These are picks for grown-ups who want a good drink, a great deck, and room to breathe. Some are serene; some are a scene. We tell you which, so you can choose your own afternoon.",
  },
  {
    numeral: "III",
    title: "Honest, Updated, Linked",
    body: "Seasonal closures, day-pass rules, resort fees, the catch nobody mentions — we keep it current and we link you straight to booking. No mystery, no bait.",
  },
];
---

<section class="standard" id="guide" aria-labelledby="standard-heading">
  <div class="section-inner">
    <header class="standard-head">
      <p class="kicker">How we pick</p>
      <h2 id="standard-heading">Three rules, no exceptions.</h2>
    </header>

    <div class="principle-grid">
      {
        principles.map((p) => (
          <article class="principle">
            <span class="ghost-num" aria-hidden="true">
              {p.numeral}
            </span>
            <div class="principle-body">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .standard {
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .standard-head {
    margin-bottom: 2.4rem;
  }

  .kicker {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--teal);
    margin-bottom: 0.9rem;
  }

  .standard-head h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.2rem, 4.2vw, 3.4rem);
    line-height: 1.08;
    color: #fff;
  }

  .principle-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid rgba(42, 120, 150, 0.2);
    border-radius: 14px;
    overflow: hidden;
  }

  .principle {
    position: relative;
    padding: clamp(1.8rem, 3vw, 2.6rem);
    overflow: hidden;
    border-right: 1px solid rgba(42, 120, 150, 0.2);
  }

  .principle:last-child {
    border-right: none;
  }

  .ghost-num {
    position: absolute;
    top: 0.4rem;
    right: 1.2rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 7.5rem;
    line-height: 1;
    color: rgba(78, 172, 184, 0.14);
    pointer-events: none;
    user-select: none;
  }

  .principle-body {
    position: relative;
    z-index: 1;
  }

  .principle-body h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.55rem;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 0.8rem;
    max-width: 14ch;
  }

  .principle-body p {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(190, 220, 228, 0.78);
  }

  @media (max-width: 900px) {
    .principle-grid {
      grid-template-columns: 1fr;
    }

    .principle {
      border-right: none;
      border-bottom: 1px solid rgba(42, 120, 150, 0.2);
    }

    .principle:last-child {
      border-bottom: none;
    }
  }
</style>

---
const principles = [
  {
    numeral: "I",
    title: "The View Has to Matter",
    body: "A pool on a roof is not automatically special. We rank for the skyline, the water line, and that specific moment the light drops and the whole deck goes gold. If the view doesn't earn it, it doesn't make the list.",
  },
  {
    numeral: "II",
    title: "Made for Grown-Ups",
    body: "These are picks for grown-ups who want a good drink, a great deck, and room to breathe. Some are serene; some are a scene. We tell you which, so you can choose your own afternoon.",
  },
  {
    numeral: "III",
    title: "No Surprises, No Bait",
    body: "Seasonal closures, day-pass rules, resort fees, the catch nobody mentions — we keep it current and link you straight to booking. What you read is what you get.",
  },
];
---

<section class="standard" id="guide" aria-labelledby="standard-heading">
  <div class="section-inner">
    <header class="standard-head">
      <p class="kicker">How we pick</p>
      <h2 id="standard-heading">Three rules, no exceptions.</h2>
    </header>

    <div class="principle-grid">
      {
        principles.map((p) => (
          <article class="principle">
            <span class="ghost-num" aria-hidden="true">
              {p.numeral}
            </span>
            <div class="principle-body">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .standard {
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .standard-head {
    margin-bottom: 2.4rem;
  }

  .standard-head .kicker,
  .standard-head h2 {
    text-shadow:
      0 1px 2px rgba(3, 12, 28, 0.55),
      0 2px 16px rgba(3, 12, 28, 0.6);
  }

  .kicker {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--teal);
    margin-bottom: 0.9rem;
  }

  .standard-head h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.2rem, 4.2vw, 3.4rem);
    line-height: 1.08;
    color: #fff;
  }

  .principle-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.6rem, 3.5vw, 3rem);
  }

  .principle {
    position: relative;
    padding: 0.4rem 0;
    overflow: hidden;
  }

  .ghost-num {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 2.6rem;
    line-height: 1;
    color: var(--teal);
    margin-bottom: 0.7rem;
    pointer-events: none;
    user-select: none;
  }

  .principle-body {
    position: relative;
    z-index: 1;
  }

  .principle-body h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.55rem;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 0.8rem;
  }

  .principle-body p {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(220, 240, 245, 0.95);
  }

  @media (max-width: 900px) {
    .principle-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

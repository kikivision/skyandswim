---
import { Image } from "astro:assets";
import fsPhilly from "../assets/picks/four-seasons-philadelphia.jpg";
import fsSeattle from "../assets/picks/four-seasons-seattle.jpg";
import conradLA from "../assets/picks/conrad-los-angeles.jpg";
import joule from "../assets/picks/the-joule-dallas.jpg";
import oneHotelSB from "../assets/picks/1-hotel-south-beach.jpg";
import gansevoort from "../assets/picks/gansevoort-new-york.jpg";

// The six best rooftop pools in the directory, ranked on Booking guest scores
// + pool-specific acclaim. Each links through the affiliate redirector.
const picks = [
  {
    name: "Four Seasons Philadelphia",
    slug: "four-seasons-philadelphia",
    city: "Philadelphia, PA",
    description:
      "A 57th-floor infinity edge atop the city's tallest tower — you swim toward the drop with Center City lit sixty stories below. The highest hotel pool in the region.",
    image: fsPhilly,
    alt: "Four Seasons Philadelphia's 57th-floor infinity pool high above the Center City skyline.",
  },
  {
    name: "Four Seasons Seattle",
    slug: "four-seasons-seattle",
    city: "Seattle, WA",
    description:
      "Seattle's only infinity hotel pool, heated to 84° year-round and open to Elliott Bay, Puget Sound, and the Olympics. Swim it in the rain — that's the point.",
    image: fsSeattle,
    alt: "Four Seasons Seattle's rooftop infinity pool overlooking Elliott Bay and the Olympic Mountains.",
  },
  {
    name: "Conrad Los Angeles",
    slug: "conrad-los-angeles",
    city: "Los Angeles, CA",
    description:
      "A Frank Gehry-designed rooftop with a 16,000-square-foot deck and an infinity pool looking clear across downtown to the Walt Disney Concert Hall.",
    image: conradLA,
    alt: "Conrad Los Angeles's Gehry-designed rooftop infinity pool over downtown LA.",
  },
  {
    name: "The Joule",
    slug: "the-joule-dallas",
    city: "Dallas, TX",
    description:
      "A pool cantilevered eight feet past the building behind glass — swim out over Main Street ten floors up and look straight down. The most distinctive pool in the country.",
    image: joule,
    alt: "The Joule's glass pool cantilevered over Main Street in downtown Dallas.",
  },
  {
    name: "1 Hotel South Beach",
    slug: "1-hotel-south-beach",
    city: "Miami Beach, FL",
    description:
      "Eighteen stories over the sand, an adults-only rooftop pool with the Atlantic laid out to the horizon — the rare scene pool that's worth the climb.",
    image: oneHotelSB,
    alt: "1 Hotel South Beach's rooftop pool eighteen stories above the Atlantic.",
  },
  {
    name: "Gansevoort Meatpacking",
    slug: "gansevoort-meatpacking",
    city: "New York, NY",
    description:
      "The heated rooftop pool that helped invent the Meatpacking scene — Hudson to the west, skyline to the east, open year-round. New York's rooftop-pool icon.",
    image: gansevoort,
    alt: "Gansevoort Meatpacking's rooftop pool with the Manhattan skyline and Hudson beyond.",
  },
];
---

<section class="picks" id="picks" aria-labelledby="picks-heading">
  <div class="section-inner">
    <header class="picks-head">
      <p class="kicker">Editor's Picks</p>
      <h2 id="picks-heading">
        The ones we keep thinking about <span class="emph">mid-scroll.</span>
      </h2>
    </header>

    <div class="pick-grid">
      {
        picks.map((pick) => (
          <article class="pick-card">
            <div class="pick-scene">
              <Image
                class="pick-img"
                src={pick.image}
                alt={pick.alt}
                widths={[360, 540, 760]}
                sizes="(max-width: 900px) 460px, 30vw"
                loading="lazy"
              />
            </div>
            <div class="pick-content">
              <p class="pick-label">✦ Sky &amp; Swim Pick</p>
              <h3 class="pick-name">
                <a
                  class="pick-name-link"
                  href={pick.slug ? `/go/booking/${pick.slug}` : pick.href}
                  target="_blank"
                  rel={pick.slug ? "noopener noreferrer sponsored" : "noopener noreferrer"}
                >{pick.name}</a>
              </h3>
              <p class="pick-city">{pick.city}</p>
              <p class="pick-desc">{pick.description}</p>
              <a
                class="pick-link"
                href={pick.slug ? `/go/booking/${pick.slug}` : pick.href}
                target="_blank"
                rel={pick.slug ? "noopener noreferrer sponsored" : "noopener noreferrer"}
              >
                See this hotel →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .picks {
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .picks-head {
    margin-bottom: 2.6rem;
    max-width: 32ch;
  }

  .picks-head .kicker,
  .picks-head h2 {
    text-shadow:
      0 1px 2px rgba(3, 12, 28, 0.55),
      0 2px 16px rgba(3, 12, 28, 0.6);
  }

  .kicker {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--teal);
    margin-bottom: 0.9rem;
  }

  .picks-head h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.2rem, 4.2vw, 3.4rem);
    line-height: 1.08;
    color: #fff;
  }

  .picks-head .emph {
    font-style: italic;
    color: rgba(200, 230, 238, 0.9);
  }

  .pick-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }

  .pick-card {
    display: flex;
    flex-direction: column;
    background: rgba(5, 24, 46, 0.8);
    border: 1px solid rgba(42, 140, 170, 0.22);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 16px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .pick-card:hover {
    transform: translateY(-4px);
    border-color: rgba(42, 191, 191, 0.5);
  }

  .pick-scene {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .pick-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pick-card:hover .pick-img {
    transform: scale(1.04);
  }

  .pick-content {
    padding: 1.5rem 1.6rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .pick-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #e85a7a;
  }

  .pick-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    line-height: 1.1;
    color: #fff;
    margin-top: 0.3rem;
  }

  .pick-name-link {
    color: inherit;
    transition: color 0.2s ease;
  }
  .pick-name-link:hover {
    color: var(--teal);
  }

  .pick-city {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(170, 210, 220, 0.8);
  }

  .pick-desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(215, 235, 240, 0.82);
    margin-top: 0.6rem;
  }

  .pick-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--teal);
    margin-top: auto;
    padding-top: 1.1rem;
    transition: color 0.2s ease;
  }

  .pick-link:hover {
    color: #fff;
  }

  @media (max-width: 900px) {
    .pick-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
    }
  }
</style>

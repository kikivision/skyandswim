---
import { Image } from "astro:assets";
import valePool from "../assets/picks/william-vale-brooklyn.jpg";
import halcyonPool from "../assets/picks/halcyon-cherry-creek-rooftop-pool.jpg";
import marquisPool from "../assets/picks/marriott-marquis-houston.jpg";

const picks = [
  {
    name: "The William Vale",
    city: "Brooklyn, NY",
    description:
      "A 60-foot rooftop pool hovering over North Brooklyn, with the Manhattan skyline laid out across the water like it owes you something.",
    href: "#",
    image: valePool,
    alt: "The William Vale's rooftop pool above North Brooklyn with the Manhattan skyline beyond.",
  },
  {
    name: "Halcyon, a Hotel in Cherry Creek",
    city: "Denver, CO",
    description:
      "A year-round heated rooftop pool that shrugs off the altitude — Rockies on the horizon, cabanas at the edge, and water blue enough to forgive the thin air.",
    href: "#",
    image: halcyonPool,
    alt: "Halcyon's rooftop pool in Cherry Creek with the Rocky Mountains on the horizon.",
  },
  {
    name: "Marriott Marquis Houston",
    city: "Houston, TX",
    description:
      "The Texas-shaped lazy river is a gimmick, yes. It is also, undeniably, a great time eight floors above downtown.",
    href: "#",
    image: marquisPool,
    alt: "The Marriott Marquis Houston's rooftop pool eight floors above downtown.",
  },
];
---

<section class="picks" id="picks" aria-labelledby="picks-heading">
  <div class="section-inner">
    <header class="picks-head">
      <p class="kicker">Editor's Picks</p>
      <h2 id="picks-heading">
        The ones we keep thinking about <span class="emph">mid-scroll.</span>
      </h2>
    </header>

    <div class="pick-grid">
      {
        picks.map((pick) => (
          <article class="pick-card">
            <div class="pick-scene">
              <Image
                class="pick-img"
                src={pick.image}
                alt={pick.alt}
                widths={[360, 540, 760]}
                sizes="(max-width: 900px) 460px, 30vw"
                loading="lazy"
              />
            </div>
            <div class="pick-content">
              <p class="pick-label">✦ Sky &amp; Swim Pick</p>
              <h3 class="pick-name">{pick.name}</h3>
              <p class="pick-city">{pick.city}</p>
              <p class="pick-desc">{pick.description}</p>
              <a class="pick-link" href={pick.href}>
                See this hotel →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .picks {
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .picks-head {
    margin-bottom: 2.6rem;
    max-width: 32ch;
  }

  .kicker {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--teal);
    margin-bottom: 0.9rem;
  }

  .picks-head h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.2rem, 4.2vw, 3.4rem);
    line-height: 1.08;
    color: #fff;
  }

  .picks-head .emph {
    font-style: italic;
    color: rgba(200, 230, 238, 0.9);
  }

  .pick-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }

  .pick-card {
    display: flex;
    flex-direction: column;
    background: rgba(5, 30, 55, 0.45);
    border: 1px solid rgba(42, 140, 170, 0.22);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 16px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .pick-card:hover {
    transform: translateY(-4px);
    border-color: rgba(42, 191, 191, 0.5);
  }

  .pick-scene {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .pick-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pick-card:hover .pick-img {
    transform: scale(1.04);
  }

  .pick-content {
    padding: 1.5rem 1.6rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .pick-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--watermelon);
  }

  .pick-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    line-height: 1.1;
    color: #fff;
    margin-top: 0.3rem;
  }

  .pick-city {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(170, 210, 220, 0.8);
  }

  .pick-desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(215, 235, 240, 0.82);
    margin-top: 0.6rem;
  }

  .pick-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--teal);
    margin-top: auto;
    padding-top: 1.1rem;
    transition: color 0.2s ease;
  }

  .pick-link:hover {
    color: #fff;
  }

  @media (max-width: 900px) {
    .pick-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
    }
  }
</style>

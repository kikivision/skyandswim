---
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sky & Swim · Rooftop Pool Hotels Across America",
  description = "Curated rooftop pool hotels across America — ranked by the view, the water, and whether the moment earns the price of admission.",
} = Astro.props;

const site = "https://skyandswim.com";
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL("/og-image.png", site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- Short label shown under the icon when added to an iOS home screen;
         without this, iOS falls back to the long <title> and crams it. -->
    <meta name="apple-mobile-web-app-title" content="Sky & Swim" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#103868" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sky & Swim" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sky & Swim — rooftop pool hotels across America" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300;1,9..40,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>

    <style is:global>
      :root {
        --robin: #a8d8d8;
        --shallow: #3a9aaa;
        --mid: #1a5a70;
        --deep: #0a2a48;
        --abyss: #050e22;
        --watermelon: #d44868;
        --teal: #2abfbf;

        --font-display: "Cormorant Garamond", Georgia, serif;
        --font-body: "DM Sans", system-ui, -apple-system, sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-body);
        font-weight: 400;
        color: #ffffff;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;

        /* The page IS the pool — a light sunlit surface at the very top that
           gradually deepens into dark water as you scroll down. One smooth
           ombre, scrolls with the page so the descent actually happens. */
        background: linear-gradient(
          180deg,
          #72b4bd 0%,
          #519ba7 11%,
          #34798d 23%,
          #22607c 37%,
          #154968 54%,
          #0b2e4e 72%,
          #050e22 100%
        );
        background-repeat: no-repeat;
      }

      main {
        display: block;
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-display);
        margin: 0;
        font-weight: 400;
      }

      p {
        margin: 0;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img,
      svg {
        display: block;
        max-width: 100%;
      }

      ::selection {
        background: rgba(212, 72, 104, 0.4);
        color: #fff;
      }

      .section-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 4vw, 3rem);
      }
    </style>
  </body>
</html>

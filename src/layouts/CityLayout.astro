---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  city: string;
  state: string;
  tagline: string;
  poolCount: number;
  neighborhoods: string;
  heroGradient?: string;
}

const {
  city,
  state,
  tagline,
  poolCount,
  neighborhoods,
  heroGradient = "linear-gradient(180deg, rgba(42,191,191,0.25) 0%, rgba(10,42,72,0.6) 100%)",
} = Astro.props;
---

<BaseLayout
  title={`${city} Rooftop Pool Hotels · Sky & Swim`}
  description={`The best rooftop pool hotels in ${city}, ${state} — ranked by view, water, and whether the moment earns the price. ${poolCount} curated picks across ${neighborhoods}.`}
>
  <div class="city-page">

    <!-- City Hero -->
    <section class="city-hero">
      <div class="hero-bg" style={`background: ${heroGradient};`} aria-hidden="true">
        <div class="water-layer" aria-hidden="true"></div>
        <div class="ripple r1" aria-hidden="true"></div>
        <div class="ripple r2" aria-hidden="true"></div>
      </div>
      <div class="hero-inner section-inner">
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All cities
        </a>
        <div class="hero-content">
          <p class="hero-kicker">Sky &amp; Swim · {state}</p>
          <h1 class="hero-city">{city}</h1>
          <p class="hero-tagline">{tagline}</p>
          <div class="hero-stats">
            <span class="stat">
              <strong>{poolCount}</strong> rooftop pools
            </span>
            <span class="stat-divider" aria-hidden="true">·</span>
            <span class="stat">{neighborhoods}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Page content slot -->
    <div class="city-body">
      <slot />
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  .city-page {
    min-height: 100vh;
  }

  /* ── Hero ── */
  .city-hero {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding-top: 6rem; /* clear fixed nav */
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .water-layer {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 60% 110%, rgba(42,191,191,0.35) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(58,154,170,0.2) 0%, transparent 60%);
  }

  .ripple {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(168, 216, 216, 0.18);
    animation: ripple-out 8s ease-out infinite;
    pointer-events: none;
  }
  .r1 {
    width: 600px; height: 600px;
    bottom: -200px; right: 5%;
    animation-delay: 0s;
  }
  .r2 {
    width: 900px; height: 900px;
    bottom: -400px; right: -5%;
    animation-delay: 3.5s;
  }

  @keyframes ripple-out {
    0%   { transform: scale(0.6); opacity: 0.5; }
    100% { transform: scale(1.1); opacity: 0; }
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding-bottom: clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    width: 100%;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(168, 216, 216, 0.7);
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #fff; }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    max-width: 680px;
  }

  .hero-kicker {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin: 0;
  }

  .hero-city {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3.5rem, 9vw, 7rem);
    line-height: 0.92;
    color: #fff;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    line-height: 1.5;
    color: rgba(220, 240, 245, 0.78);
    margin: 0.4rem 0 0;
    max-width: 55ch;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }

  .stat {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(168, 216, 216, 0.85);
  }
  .stat strong {
    font-weight: 600;
    color: #fff;
  }
  .stat-divider { color: rgba(168, 216, 216, 0.4); }

  /* ── Body ── */
  .city-body {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 640px) {
    .city-hero { min-height: 45vh; }
  }
</style>

---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CityMotif from "../components/CityMotif.astro";

interface Props {
  city: string;
  state: string;
  tagline: string;
  poolCount: number;
  neighborhoods: string;
  heroGradient?: string;
  skyline?: boolean;
  motif?: string;
}

const {
  city,
  state,
  tagline,
  poolCount,
  neighborhoods,
  heroGradient = "linear-gradient(180deg, rgba(42,191,191,0.25) 0%, rgba(10,42,72,0.6) 100%)",
  skyline = false,
  motif,
} = Astro.props;
---

<BaseLayout
  title={`${city} Rooftop Pool Hotels · Sky & Swim`}
  description={`The best rooftop pool hotels in ${city}, ${state} — ranked by view, water, and whether the moment earns the price. ${poolCount} curated picks across ${neighborhoods}.`}
>
  <div class="city-page">

    <!-- City Hero -->
    <section class="city-hero">
      <div class="hero-bg" style={`background: ${heroGradient};`} aria-hidden="true">
        <div class="water-layer" aria-hidden="true"></div>
        {!skyline && !motif && (
          <Fragment>
            <div class="ripple r1" aria-hidden="true"></div>
            <div class="ripple r2" aria-hidden="true"></div>
            <div class="ripple r3" aria-hidden="true"></div>
          </Fragment>
        )}
        {motif && <CityMotif name={motif} />}
        {skyline && (
          <div class="hero-skyline" aria-hidden="true">
            <svg viewBox="0 0 640 240" preserveAspectRatio="xMaxYMax meet">
              <path d="M0,240 L0,198 L26,198 L26,166 L50,166 L50,206 L66,206 L66,146 L94,146 L94,182 L120,182 L120,118 L131,118 L131,92 L137,70 L143,92 L143,118 L156,118 L156,176 L184,176 L184,150 L210,150 L210,192 L236,192 L236,132 L262,132 L262,170 L286,170 L286,114 L300,114 L300,82 L306,58 L312,82 L312,114 L326,114 L326,158 L352,158 L352,188 L380,188 L380,138 L408,138 L408,176 L432,176 L432,108 L444,108 L444,150 L470,150 L470,120 L476,120 L476,88 L482,88 L482,182 L508,182 L508,146 L534,146 L534,98 L546,62 L552,62 L564,98 L564,160 L590,160 L590,190 L616,190 L616,150 L640,150 L640,240 Z" fill="currentColor"></path>
            </svg>
          </div>
        )}
      </div>
      <div class="hero-inner section-inner">
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All cities
        </a>
        <div class="hero-content">
          <p class="hero-kicker">Sky &amp; Swim · {state}</p>
          <h1 class="hero-city">{city}</h1>
          <p class="hero-tagline">{tagline}</p>
          <div class="hero-stats">
            <span class="stat">
              <strong>{poolCount}</strong> rooftop pools
            </span>
            <span class="stat-divider" aria-hidden="true">·</span>
            <span class="stat">{neighborhoods}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Page content slot -->
    <div class="city-body">
      <slot />
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  .city-page {
    min-height: 100vh;
  }

  /* ── Hero ── */
  .city-hero {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding-top: 6rem; /* clear fixed nav */
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .water-layer {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 60% 110%, rgba(42,191,191,0.35) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(58,154,170,0.2) 0%, transparent 60%);
  }

  .ripple {
    position: absolute;
    bottom: -60px;
    right: 15%;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    border: 1px solid rgba(168, 216, 216, 0.3);
    opacity: 0;
    animation: ripple-out 4.2s ease-out infinite;
    pointer-events: none;
  }
  .r1 { animation-delay: 0s; }
  .r2 { animation-delay: 1.4s; }
  .r3 { animation-delay: 2.8s; }

  @keyframes ripple-out {
    0%   { transform: scale(0.1); opacity: 0; }
    16%  { opacity: 0.55; }
    100% { transform: scale(1); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ripple { animation: none; opacity: 0; }
  }

  /* Faint city skyline in the top-right of the hero — used in place of a
     color personality (e.g. New York). */
  .hero-skyline {
    position: absolute;
    top: 0;
    right: 0;
    width: min(62%, 620px);
    height: 58%;
    color: rgba(190, 228, 234, 0.2);
    -webkit-mask-image: linear-gradient(180deg, #000 50%, transparent 100%);
    mask-image: linear-gradient(180deg, #000 50%, transparent 100%);
    pointer-events: none;
  }
  .hero-skyline svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding-bottom: clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    width: 100%;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(168, 216, 216, 0.7);
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #fff; }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    max-width: 680px;
  }

  .hero-kicker {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin: 0;
  }

  .hero-city {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3.5rem, 9vw, 7rem);
    line-height: 0.92;
    color: #fff;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    line-height: 1.5;
    color: rgba(220, 240, 245, 0.78);
    margin: 0.4rem 0 0;
    max-width: 55ch;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }

  .stat {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(168, 216, 216, 0.85);
  }
  .stat strong {
    font-weight: 600;
    color: #fff;
  }
  .stat-divider { color: rgba(168, 216, 216, 0.4); }

  /* ── Body ── */
  .city-body {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 640px) {
    .city-hero { min-height: 45vh; }
  }
</style>

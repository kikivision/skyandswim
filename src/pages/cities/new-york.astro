---
import CityLayout from "../../layouts/CityLayout.astro";
import HotelCard from "../../components/HotelCard.astro";

const hotels = [
  {
    name: "The William Vale",
    neighborhood: "Williamsburg",
    description: "A 60-foot rooftop pool hovering over North Brooklyn, with the Manhattan skyline laid out across the water like it owes you something. The views change character with the light — blinding at noon, cinematic at dusk.",
    poolNote: "60-ft heated infinity edge pool · Day passes available · Elevated deck bar",
    tags: ["Infinity Edge", "Day Pass", "Skyline View", "Adults-Focused"],
    bookingUrl: "https://www.thewilliamvale.com",
    pick: true,
    priceRange: "$$$",
  },
  {
    name: "1 Hotel Brooklyn Bridge",
    neighborhood: "DUMBO",
    description: "Rooftop pool and bar perched between the Brooklyn and Manhattan bridges, with a biophilic design ethos that somehow makes a rooftop feel like a clearing in a forest. The bar program earns its real estate.",
    poolNote: "Year-round heated pool · Eco-certified · Bridge-to-bridge sightlines",
    tags: ["Year-Round", "Eco", "Bridge Views", "Bar"],
    bookingUrl: "https://www.1hotels.com/brooklyn-bridge",
    priceRange: "$$$",
  },
  {
    name: "Arlo Williamsburg",
    neighborhood: "Williamsburg",
    description: "Compact but capable — the rooftop pool is on the smaller side but is rarely crowded at the right hours. Good for an afternoon session, especially mid-week when the deck becomes genuinely calm.",
    poolNote: "Seasonal heated pool · Best mid-week · Happy hour deals",
    tags: ["Seasonal", "Happy Hour", "Uncrowded"],
    priceRange: "$$",
  },
  {
    name: "Jimmy at The James Hotel",
    neighborhood: "SoHo",
    description: "Manhattan's most reliably fun rooftop pool — the scene is the point, and it delivers on sunny weekends. The skyline here angles south, which gives you One World Trade in the frame from the water.",
    poolNote: "Day passes with food & drink minimum · Manhattan skyline · Weekend scene",
    tags: ["Scene", "Day Pass", "Manhattan", "Views South"],
    bookingUrl: "https://www.jimmysoho.com",
    priceRange: "$$$",
  },
  {
    name: "Sixty SoHo",
    neighborhood: "SoHo",
    description: "A quieter Manhattan rooftop that trades the party energy for a more European feel — comfortable loungers, no DJ, good cocktails. The pool isn't large but the deck has a sense of proportion that rewards the price.",
    poolNote: "Boutique rooftop pool · Guest-priority access · No DJ policy",
    tags: ["Adults-Only", "Quiet", "Boutique"],
    priceRange: "$$$",
  },
  {
    name: "THEhotel at Mandarin Club",
    neighborhood: "Midtown West",
    description: "Midtown's surprising option — a glass-edged pool that looks directly at the Hudson and into New Jersey sunsets. The height gives the whole deck a slightly vertiginous quality that somehow makes the drinks taste better.",
    poolNote: "Glass edge · Hudson River views · Sunset-facing west",
    tags: ["Glass Edge", "River Views", "Sunset"],
    priceRange: "$$$$",
  },
  {
    name: "Hotel 50 Bowery",
    neighborhood: "Chinatown",
    description: "The best rooftop in Lower Manhattan for value, especially if you book a room. The pool is compact and the views are downtown — Woolworth, the bridges, all of it. An underrated pick in a neighborhood that punches up.",
    poolNote: "Downtown views · Best value in lower Manhattan · Small heated pool",
    tags: ["Value", "Downtown Views", "Compact"],
    bookingUrl: "https://www.hotel50bowery.com",
    priceRange: "$$",
  },
  {
    name: "Wythe Hotel",
    neighborhood: "Williamsburg",
    description: "Not technically a pool hotel — the rooftop bar is the draw here, with Manhattan backdrop views that rival anything with water. Listed because the rooftop experience is consistently exceptional and deserves a place in the conversation.",
    poolNote: "Rooftop bar (no pool) · Panoramic Manhattan views · Strong cocktail program",
    tags: ["Bar Only", "Panoramic", "Views"],
    bookingUrl: "https://www.wythehotel.com",
    priceRange: "$$",
  },
  {
    name: "The Williamsburg Hotel",
    neighborhood: "Williamsburg",
    description: "A water tower pool sits above the Williamsburg roofscape — an unexpectedly intimate setting for a neighborhood that's become anything but. The industrial detail of the space makes it feel like a discovery.",
    poolNote: "Water tower pool · Boutique atmosphere · Neighborhood roofscape views",
    tags: ["Water Tower", "Boutique", "Unique"],
    bookingUrl: "https://www.thewilliamsburghotel.com",
    priceRange: "$$$",
  },
];
---

<CityLayout
  city="New York"
  state="NY"
  tagline="Manhattan on one side, Brooklyn on the other, the East River between them — every rooftop pool in this city has an opinion about which view is worth more."
  poolCount={9}
  neighborhoods="Manhattan & Brooklyn"
  heroGradient="linear-gradient(180deg, rgba(26,80,110,0.5) 0%, rgba(10,42,72,0.75) 100%)"
>
  <section class="city-listings">
    <div class="section-inner">

      <div class="listings-header">
        <p class="listings-kicker">9 picks · Manhattan &amp; Brooklyn</p>
        <h2 class="listings-heading">Every pool, ranked honestly.</h2>
        <p class="listings-lede">
          Our top pick is starred. The rest are ordered by how often we'd choose them
          given a free afternoon and a willing companion.
        </p>
      </div>

      <div class="hotel-grid">
        {hotels.map((hotel) => (
          <HotelCard {...hotel} />
        ))}
      </div>

      <aside class="city-note">
        <p><strong>What we look for in New York:</strong> The city has more rooftop pools than any other on this list, which means there are also more bad ones. We filter for unobstructed skyline sight-lines, a functioning day-pass option, and a bar program that isn't an afterthought. The ones here survived all three tests.</p>
      </aside>

    </div>
  </section>
</CityLayout>

<style>
  .city-listings {
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(4rem, 8vw, 7rem);
  }

  /* Deep-navy scrim so the intro reads over any part of the fixed pool
     gradient — the shallow (light) end otherwise washes the copy out. */
  .listings-header {
    max-width: 56ch;
    margin-bottom: 2.8rem;
    padding: clamp(1.4rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2.2rem);
    background: linear-gradient(
      180deg,
      rgba(5, 20, 40, 0.6) 0%,
      rgba(5, 20, 40, 0.42) 100%
    );
    border: 1px solid rgba(168, 216, 216, 0.12);
    border-radius: 16px;
  }

  .listings-kicker {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--robin);
    margin: 0 0 0.8rem;
  }

  .listings-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    margin: 0 0 0.8rem;
    line-height: 1.05;
  }

  .listings-lede {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(220, 240, 245, 0.7);
    margin: 0;
  }

  .hotel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 420px), 1fr));
    gap: 1.25rem;
  }

  .city-note {
    margin-top: 3rem;
    padding: 1.6rem 2rem;
    border-left: 2px solid rgba(42, 191, 191, 0.3);
    background: rgba(42, 191, 191, 0.05);
    border-radius: 0 8px 8px 0;
    max-width: 72ch;
  }

  .city-note p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(220, 240, 245, 0.75);
    margin: 0;
  }

  .city-note strong {
    font-weight: 500;
    color: rgba(220, 240, 245, 0.95);
  }
</style>

---
import CityLayout from "../../layouts/CityLayout.astro";
import HotelCard from "../../components/HotelCard.astro";

const hotels = [
  {
    name: "The Ace Hotel New Orleans",
    neighborhood: "Warehouse District",
    description: "The rooftop pool at the Ace occupies the building's converted upper floors with the Superdome visible and the downtown grid below. The water is warmer than the city deserves, and the bar program goes past the obligatory hurricane offerings into something more considered.",
    poolNote: "Year-round heated pool · Superdome views · Warehouse District rooftop · Strong bar",
    tags: ["Year-Round", "Superdome Views", "Bar", "Warehouse District"],
    bookingUrl: "https://www.acehotel.com/new-orleans",
    pick: true,
    priceRange: "$$",
  },
  {
    name: "The Higgins Hotel",
    neighborhood: "Warehouse District",
    description: "The National WWII Museum's boutique hotel carries a thoughtfulness into its rooftop design — a clean pool deck with downtown views and a crowd that skews quieter and older than the Quarter. The bar references local history without being precious about it.",
    poolNote: "Rooftop pool · Downtown views · Museum adjacent · Thoughtful bar program",
    tags: ["Quiet", "History", "Downtown", "Boutique"],
    bookingUrl: "https://www.thehigginshotel.com",
    priceRange: "$$",
  },
  {
    name: "Virgin Hotels New Orleans",
    neighborhood: "Warehouse District",
    description: "Virgin's rooftop pool — called The Pool Club — carries the brand's social energy to the top of the Warehouse District with Mississippi River views in the distance. The pool is properly sized and the whole deck is open to day-pass guests, which keeps the energy up.",
    poolNote: "The Pool Club · Mississippi River distant views · Day passes · Social scene",
    tags: ["Day Pass", "Scene", "River Views", "Social"],
    bookingUrl: "https://virginhotels.com/new-orleans",
    priceRange: "$$",
  },
];
---

<CityLayout
  city="New Orleans"
  state="LA"
  tagline="New Orleans doesn't do rooftop pools the way other cities do — the city is at sea level, the architecture runs low and lateral, and the pleasure principle here is horizontal, not vertical. But the three that make the list are genuinely excellent."
  poolCount={3}
  neighborhoods="Warehouse District"
  heroGradient="linear-gradient(180deg, rgba(30,65,50,0.45) 0%, rgba(5,20,45,0.8) 100%)"
>
  <section class="city-listings">
    <div class="section-inner">

      <div class="listings-header">
        <p class="listings-kicker">3 picks · Warehouse District</p>
        <h2 class="listings-heading">Three pools, no argument.</h2>
        <p class="listings-lede">
          New Orleans has exactly three rooftop pools worth recommending. We picked all three. The city compensates by making the bars on each better than they need to be.
        </p>
      </div>

      <div class="hotel-grid">
        {hotels.map((hotel) => (
          <HotelCard {...hotel} />
        ))}
      </div>

      <aside class="city-note">
        <p><strong>Why the Warehouse District:</strong> The French Quarter's historic building stock doesn't allow for rooftop development in the same way. The Warehouse District has absorbed the city's new boutique hotel inventory, and the three pools here are all within a reasonable walk of each other — easy to compare, easier to commit to.</p>
      </aside>

    </div>
  </section>
</CityLayout>

<style>
  .city-listings { padding: clamp(3rem, 6vw, 5rem) 0 clamp(4rem, 8vw, 7rem); }
  .listings-header { max-width: 56ch; margin-bottom: 2.8rem; padding: clamp(1.4rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2.2rem); background: linear-gradient(180deg, rgba(5, 20, 40, 0.6) 0%, rgba(5, 20, 40, 0.42) 100%); border: 1px solid rgba(168, 216, 216, 0.12); border-radius: 16px; }
  .listings-kicker { font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: var(--robin); margin: 0 0 0.8rem; }
  .listings-heading { font-family: var(--font-display); font-weight: 400; font-size: clamp(2rem, 4vw, 3rem); color: #fff; margin: 0 0 0.8rem; line-height: 1.05; }
  .listings-lede { font-family: var(--font-body); font-weight: 300; font-size: 1rem; line-height: 1.6; color: rgba(220, 240, 245, 0.7); margin: 0; }
  .hotel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 420px), 1fr)); gap: 1.25rem; }
  .city-note { margin-top: 3rem; padding: 1.6rem 2rem; border-left: 2px solid rgba(42, 191, 191, 0.3); background: rgba(42, 191, 191, 0.05); border-radius: 0 8px 8px 0; max-width: 72ch; }
  .city-note p { font-family: var(--font-body); font-size: 0.9rem; font-weight: 300; line-height: 1.65; color: rgba(220, 240, 245, 0.75); margin: 0; }
  .city-note strong { font-weight: 500; color: rgba(220, 240, 245, 0.95); }
</style>

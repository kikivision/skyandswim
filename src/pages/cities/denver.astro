---
import CityLayout from "../../layouts/CityLayout.astro";
import HotelCard from "../../components/HotelCard.astro";

const hotels = [
  {
    name: "Halcyon, a Hotel in Cherry Creek",
    neighborhood: "Cherry Creek",
    description: "A year-round heated rooftop pool that shrugs off the altitude — Rockies on the horizon, cabanas at the edge, and water blue enough to forgive the thin air. The 14ers visible from the pool deck on a clear morning are the kind of view that makes the resort fee feel optional.",
    poolNote: "Year-round heated pool · Rocky Mountain views · Cabanas · Cherry Creek setting",
    tags: ["Year-Round", "Mountain Views", "Cabanas", "Heated"],
    bookingUrl: "https://www.halcyonhotelcherrycreek.com",
    pick: true,
    priceRange: "$$$",
  },
  {
    name: "The Maven Hotel",
    neighborhood: "RiNo / Ballpark",
    description: "Denver's Dairy Block neighborhood has become the city's most interesting food and drink corridor, and The Maven's rooftop pool sits above it with the downtown skyline framing the Front Range in the distance. An underrated position in a neighborhood worth staying in.",
    poolNote: "Dairy Block rooftop · Downtown + mountain framing · Seasonal · Neighborhood gem",
    tags: ["RiNo", "Downtown Views", "Seasonal", "Boutique"],
    bookingUrl: "https://www.themavenhotel.com",
    priceRange: "$$",
  },
  {
    name: "The Crawford Hotel",
    neighborhood: "LoDo / Union Station",
    description: "Built inside Denver Union Station, The Crawford's rooftop pool is small but the setting is architecturally remarkable. The Denver tech and creative class fills the deck on summer evenings; the pool becomes the best place to watch the Front Range light shift.",
    poolNote: "Union Station setting · Small pool · Front Range light · Summer evenings",
    tags: ["Unique Setting", "Architecture", "LoDo", "Compact"],
    bookingUrl: "https://www.thecrawfordhotel.com",
    priceRange: "$$$",
  },
  {
    name: "Art Hotel Denver",
    neighborhood: "Golden Triangle",
    description: "The Art Hotel's pool deck is the city's most visually considered space — the collection extends to the exterior, and the pool deck design has a clarity that most Denver hotels haven't achieved yet. Mountain views and a quieter Golden Triangle neighborhood make this the anti-LoDo option.",
    poolNote: "Design hotel pool · Golden Triangle · Art collection · Mountain views",
    tags: ["Design", "Art Hotel", "Golden Triangle", "Quiet"],
    bookingUrl: "https://www.thearthotel.com",
    priceRange: "$$$",
  },
];
---

<CityLayout
  city="Denver"
  state="CO"
  tagline="At 5,280 feet, every pool in Denver is technically a mile high — but the ones worth visiting earn that designation not with altitude but with mountains on the horizon and water warm enough to stay in through a thin-air afternoon."
  poolCount={4}
  neighborhoods="LoDo & RiNo"
  heroGradient="linear-gradient(180deg, rgba(20,55,80,0.45) 0%, rgba(8,25,55,0.8) 100%)"
>
  <section class="city-listings">
    <div class="section-inner">

      <div class="listings-header">
        <p class="listings-kicker">4 picks · LoDo &amp; RiNo</p>
        <h2 class="listings-heading">The Rockies, framed in water.</h2>
        <p class="listings-lede">
          Denver's best rooftop pools face west — which means the Rocky Mountains are in the frame, and the afternoon light eventually turns the snowcaps pink. The four here have the views to prove it.
        </p>
      </div>

      <div class="hotel-grid">
        {hotels.map((hotel) => (
          <HotelCard {...hotel} />
        ))}
      </div>

      <aside class="city-note">
        <p><strong>Year-round is meaningful here:</strong> Denver averages 300 days of sunshine a year, but the altitude means summer afternoons can drop 30 degrees between 2pm and 8pm. Halcyon and a few others heat their pools year-round, which means a clear January afternoon with Rockies visible is genuinely on the table. Pack a towel in both seasons.</p>
      </aside>

    </div>
  </section>
</CityLayout>

<style>
  .city-listings { padding: clamp(3rem, 6vw, 5rem) 0 clamp(4rem, 8vw, 7rem); }
  .listings-header { max-width: 56ch; margin-bottom: 2.8rem; padding: clamp(1.4rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2.2rem); background: linear-gradient(180deg, rgba(5, 20, 40, 0.6) 0%, rgba(5, 20, 40, 0.42) 100%); border: 1px solid rgba(168, 216, 216, 0.12); border-radius: 16px; }
  .listings-kicker { font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: var(--robin); margin: 0 0 0.8rem; }
  .listings-heading { font-family: var(--font-display); font-weight: 400; font-size: clamp(2rem, 4vw, 3rem); color: #fff; margin: 0 0 0.8rem; line-height: 1.05; }
  .listings-lede { font-family: var(--font-body); font-weight: 300; font-size: 1rem; line-height: 1.6; color: rgba(220, 240, 245, 0.7); margin: 0; }
  .hotel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 420px), 1fr)); gap: 1.25rem; }
  .city-note { margin-top: 3rem; padding: 1.6rem 2rem; border-left: 2px solid rgba(42, 191, 191, 0.3); background: rgba(42, 191, 191, 0.05); border-radius: 0 8px 8px 0; max-width: 72ch; }
  .city-note p { font-family: var(--font-body); font-size: 0.9rem; font-weight: 300; line-height: 1.65; color: rgba(220, 240, 245, 0.75); margin: 0; }
  .city-note strong { font-weight: 500; color: rgba(220, 240, 245, 0.95); }
</style>

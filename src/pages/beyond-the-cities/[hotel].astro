---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import HotelDetail from "../../components/HotelDetail.astro";
import { BEYOND_HOTELS } from "../../data/beyond.js";

// A detail page per Beyond-the-Cities standout — one exceptional pool in a city
// without its own page. Shares HotelDetail with the city hotels and Notable
// Pools; single-sourced from beyond.js so the grid and the detail never drift.
// Breadcrumb parent is Beyond the Cities (no city home). Hero photo is drop-in
// by filename (src/assets/hotels/<slug>.jpg) and renders once pulled.
//
// four-seasons-seattle is skipped: it's a homepage Editor's Pick with its own
// standalone page at /hotels/four-seasons-seattle/ (and lacks the area/city/
// state fields the kicker needs here).
export function getStaticPaths() {
  return BEYOND_HOTELS.filter((h) => h.slug !== "four-seasons-seattle").map((h) => ({
    params: { hotel: h.slug },
    props: { hotel: h },
  }));
}

const { hotel } = Astro.props;
const { city, state } = hotel;

// The detail kicker reads "<area> · <city>, <state>", so hand HotelDetail a
// neighborhood of just the sub-area (the grid label carries the city).
const detailHotel = { ...hotel, neighborhood: hotel.area };

const poolFacts = hotel.poolNote
  .split("·")
  .map((s) => s.trim())
  .filter(Boolean);

const site = "https://skyandswim.com";
const pageUrl = `${site}/beyond-the-cities/${hotel.slug}/`;

const title = `${hotel.name} Rooftop Pool · ${city}, ${state} · Sky & Swim`;
const description = `${hotel.name} in ${city}, ${state} — ${poolFacts.join(", ")}. Our honest take on whether the pool earns the price.`.slice(
  0,
  155,
);

const jsonLd = [
  {
    "@type": "Hotel",
    "@id": `${pageUrl}#hotel`,
    name: hotel.name,
    description: hotel.description,
    url: pageUrl,
    address: {
      "@type": "PostalAddress",
      addressLocality: city,
      addressRegion: state,
      addressCountry: "US",
    },
    ...(hotel.priceRange ? { priceRange: hotel.priceRange } : {}),
    amenityFeature: [
      { "@type": "LocationFeatureSpecification", name: "Rooftop pool", value: true },
      ...poolFacts.map((f) => ({
        "@type": "LocationFeatureSpecification",
        name: f,
        value: true,
      })),
    ],
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
      {
        "@type": "ListItem",
        position: 2,
        name: "Beyond the Cities",
        item: `${site}/beyond-the-cities/`,
      },
      { "@type": "ListItem", position: 3, name: hotel.name, item: pageUrl },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <HotelDetail
    hotel={detailHotel}
    city={city}
    state={state}
    parentLabel="Beyond the Cities"
    parentHref="/beyond-the-cities/"
  />
  <Footer />
</BaseLayout>
